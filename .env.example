# ALSA capture device - find with: arecord -l
# hw:0,0 = first card, hw:1,0 = second card (USB devices usually card 1+)
ALSA_DEVICE=hw:0,0

# Audio format
SAMPLE_RATE=48000
CHANNELS=2
BIT_DEPTH=24

# Relay settings
RELAY_PORT=8100
MOUNT_POINT=live.flac

# Stream metadata
STREAM_NAME=Audio Source

# Chunk size for broadcasting to clients (bytes)
CHUNK_SIZE=4096

# ffmpeg thread queue size (increase if you see overrun warnings)
THREAD_QUEUE_SIZE=4096
