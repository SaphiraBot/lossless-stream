# ── Audio Capture ────────────────────────────────────────────────────
# ALSA capture device — find yours with: arecord -l
# hw:0,0 = first card, hw:1,0 = second card (USB devices usually card 1+)
ALSA_DEVICE=hw:0,0

# Audio format
SAMPLE_RATE=48000
CHANNELS=2
BIT_DEPTH=24

# ── Relay Settings ───────────────────────────────────────────────────
# HTTP port the stream is served on
RELAY_PORT=8100

# URL mount path (stream URL = http://host:port/<mount>)
MOUNT_POINT=live.flac

# Stream name (shown in logs and /metadata endpoint)
STREAM_NAME=Audio Source

# Broadcast chunk size in bytes
CHUNK_SIZE=4096

# ffmpeg thread queue size (increase if you see overrun warnings)
THREAD_QUEUE_SIZE=4096

# ── Listener Limits ─────────────────────────────────────────────────
# Max simultaneous listeners (new connections get HTTP 503 when full)
MAX_LISTENERS=10

# Per-client write buffer limit in KB — slow clients exceeding this are dropped
MAX_QUEUE_SIZE_KB=512

# ── Source Monitoring ────────────────────────────────────────────────
# Seconds of silence from ffmpeg before source is flagged as timed-out
SOURCE_TIMEOUT=10

# ── Timeouts ─────────────────────────────────────────────────────────
# Idle-connection / keep-alive timeout in seconds
HEADER_TIMEOUT=15

# ── Recording ────────────────────────────────────────────────────────
# Optional: path to record the raw FLAC stream to a file (leave empty to disable)
# RECORD_FILE=/data/recording.flac

# ── Custom Headers ───────────────────────────────────────────────────
# Optional: JSON object of extra HTTP headers to add to stream responses
# Useful for reverse proxy setups
# EXTRA_HEADERS={"X-Custom-Header": "value"}
